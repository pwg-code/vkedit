{
  "name": "vkedit",
  "version": "3.2.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "description": "A powerful and extensible graphic editor plugin library based on Vue 3 and Konva.js for label template design, QR code design, barcode design, receipt design, business card design, certificate design, and more. Supports rectangle, text, line, table, QR code, barcode, and chart elements with plugin architecture, undo/redo, import/export to JSON/PNG/JPG/PDF, alignment tools, and canvas manipulation.",
  "module": "dist/vkedit.es.js",
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && pnpm pack",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "build:css": "vite build"
  },
  "peerDependencies": {
    "konva": "^10.0.2",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-konva": "^3.2.6"
  },
  "keywords": [
    "vue3",
    "vue",
    "konva",
    "vue-konva",
    "canvas",
    "typescript",
    "editor",
    "graphic-editor",
    "designer",
    "label-designer",
    "barcode",
    "qrcode",
    "chart",
    "table",
    "print",
    "receipt",
    "invoice",
    "business-card",
    "certificate",
    "plugin",
    "svg",
    "pdf",
    "export",
    "import",
    "undo",
    "redo",
    "alignment",
    "ruler",
    "zoom",
    "drag",
    "pinia",
    "component"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.4.2",
    "lucide-vue-next": "^0.546.0",
    "npm-run-all2": "^8.0.4",
    "pinia": "^3.0.3",
    "prettier": "3.6.2",
    "primevue": "^4.4.1",
    "sass-embedded": "^1.83.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@vueuse/core": "^14.0.0",
    "echarts": "^6.0.0",
    "exceljs": "^4.4.0",
    "jsbarcode": "^3.11.5",
    "jspdf": "^3.0.3",
    "lodash": "^4.17.21",
    "qrcode": "^1.5.1",
    "uuid": "^13.0.0"
  },
